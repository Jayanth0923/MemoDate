{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "username": { "type": "string", "description": "Unique username" },
        "email": { "type": "string", "description": "User email" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "username", "email"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A memory entry tied to a specific date",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique memory ID" },
        "userId": { "type": "string", "description": "ID of the user who created the memory" },
        "date": { "type": "string", "format": "date", "description": "The date this memory is tied to (YYYY-MM-DD)" },
        "text": { "type": "string", "description": "Text content of the memory" },
        "mediaUrls": { "type": "array", "items": { "type": "string" }, "description": "URLs of images/videos" },
        "taggedUserIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of tagged users" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the memory was created" }
      },
      "required": ["userId", "date", "text"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Memory entries"
    }
  }
}
